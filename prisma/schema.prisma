generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Staff {
  id            Int      @id @default(autoincrement())
  name          String
  role          String
  department    String?
  qualification String?
  email         String?
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([role])
  @@index([department])
  @@index([createdAt])
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  dateISO   String
  category  String?
  summary   String?
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([dateISO])
  @@index([createdAt])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  dateISO     String
  time        String?
  location    String?
  type        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([dateISO])
  @@index([createdAt])
}

model AdminUser {
  id       Int    @id @default(autoincrement())
  username String @unique
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

model Course {
  id          Int      @id @default(autoincrement())
  name        String
  category    String // e.g., 'Undergraduate' or 'Postgraduate'
  duration    String
  description String?
  department  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([department])
  @@index([createdAt])
}
