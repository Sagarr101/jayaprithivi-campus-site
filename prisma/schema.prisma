generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Staff {
  id           Int      @id @default(autoincrement())
  name         String
  role         String
  department   String?
  qualification String?
  email        String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  dateISO   String
  category  String?
  summary   String?
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id        Int      @id @default(autoincrement())
  title     String
  dateISO   String
  time      String?
  location  String?
  type      String?
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id       Int    @id @default(autoincrement())
  username String @unique
  // For now we will not store passwords here; we will protect admin
  // routes via a shared secret in environment variables.
}

