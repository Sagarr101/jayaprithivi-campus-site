generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Query {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("open") // open, resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  category  String?
  content   String
  dateISO   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([dateISO])
  @@index([createdAt])
}

model Staff {
  id            Int      @id @default(autoincrement())
  name          String
  role          String
  department    String?
  qualification String?
  email         String?
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([role])
  @@index([department])
  @@index([createdAt])
}

model Admission {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  phone       String?
  course      String
  documentUrl String?
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([course])
  @@index([createdAt])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  dateISO     String
  time        String?
  location    String?
  type        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([dateISO])
  @@index([createdAt])
}

model AdminUser {
  id       Int    @id @default(autoincrement())
  username String @unique
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

model Course {
  id          Int      @id @default(autoincrement())
  name        String
  category    String // e.g., 'Undergraduate' or 'Postgraduate'
  duration    String
  description String?
  department  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([department])
  @@index([createdAt])
}
